# Path to your ROMs directory (absolute path on host)
ROM_PATH=/path/to/your/roms

# Authentication
AUTH__USERNAME=admin
AUTH__PASSWORD=change-me

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random ephemeral key is generated at startup (sessions lost on restart)
SECRET_KEY=change-this-in-production

# Scraper Credentials (ScreenScraper.fr — free account required)
SCRAPER__USERNAME=
SCRAPER__PASSWORD=

# ScreenScraper Developer credentials (optional — defaults to bundled fallback)
# Register at https://www.screenscraper.fr/
SCRAPER__SS_DEV_ID=
SCRAPER__SS_DEV_PASSWORD=
SCRAPER__SS_SOFTNAME=jarl

# IGDB Credentials (dev.twitch.tv — free Twitch account required)
SCRAPER__IGDB_CLIENT_ID=
SCRAPER__IGDB_CLIENT_SECRET=

# Rate limiting (seconds between ScreenScraper requests — default 2.0)
# SCRAPER__RATE_LIMIT=2.0

# Scanner tuning (optional)
# SCANNER__WORKERS=4
# SCANNER__HASH_SIZE_LIMIT_MB=512
# SCANNER__FILE_TIMEOUT_SECONDS=30
