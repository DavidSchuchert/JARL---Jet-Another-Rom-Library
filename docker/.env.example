# Path to your ROMs directory (absolute path on host)
ROM_PATH=/path/to/your/roms

# Authentication
AUTH__USERNAME=admin
AUTH__PASSWORD=admin

# Scraper Credentials (ScreenScraper.fr)
SCRAPER__USERNAME=
SCRAPER__PASSWORD=

# IGDB Credentials (dev.twitch.tv)
SCRAPER__IGDB_CLIENT_ID=
SCRAPER__IGDB_CLIENT_SECRET=

# Security
SECRET_KEY=change-this-in-production
